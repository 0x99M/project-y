# Paddle webhook (transaction.completed event)
PADDLE_WEBHOOK_SECRET=

# Paddle server-side API key — used to fetch customer email by customer_id
# Dashboard: Developer tools → Authentication → API keys
PADDLE_API_KEY=

# Ed25519 private key for signing license keys (PEM format)
LICENSE_PRIVATE_KEY=

# Resend.com API key for sending license emails
RESEND_API_KEY=

# Sender address. Leave unset in production to default to noreply@clipmer.app.
# For local testing before domain verification, use: Clipmer <onboarding@resend.dev>
# (only delivers to the email that owns the Resend account)
RESEND_FROM=

# Paddle.js client-side config — public, safe to expose in the browser
# Get token from Paddle dashboard → Developer tools → Authentication → Client-side tokens
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_PRICE_ID=
NEXT_PUBLIC_PADDLE_ENV=sandbox

# Master switch for the "Buy Pro" button on /pro.
# Unset / anything other than "true" → button shows "Coming soon" and does
# not initialize Paddle.js. Set to "true" (along with the Paddle vars above)
# to enable live checkout.
NEXT_PUBLIC_BUY_PRO_ENABLED=false
