  <name>Clipmer</name>
  <summary>Clipboard history manager for Linux</summary>

  <developer id="app.clipmer">
    <name>0x99M</name>
  </developer>

  <description>
    <p>
      Clipmer keeps a searchable history of everything you copy, so you can
      paste something from five minutes ago without re-copying it.
    </p>
    <p>Features:</p>
    <ul>
      <li>Searchable history of recent copies, capped and de-duplicated</li>
      <li>Folders for organizing snippets you reach for often</li>
      <li>Inline notes on any entry</li>
      <li>Global shortcut to summon the popup from anywhere</li>
      <li>Keyboard-driven: arrow keys to navigate, Enter to paste</li>
      <li>Auto-paste back into the window you were just in</li>
      <li>100% offline — no telemetry, no analytics, no account</li>
    </ul>
  </description>

  <launchable type="desktop-id">app.clipmer.Clipmer.desktop</launchable>

  <url type="homepage">https://clipmer.app</url>
  <url type="bugtracker">https://github.com/0x99M/project-y/issues</url>
  <url type="vcs-browser">https://github.com/0x99M/project-y</url>

  <!-- TODO before submitting to Flathub: replace with at least one real,
