{
  "name": "clipmer",
  "version": "3.0.4",
  "description": "Clipboard history manager for Linux",
  "author": {
    "name": "Mustafa",
    "email": "mustafa@clipmer.local"
  },
  "homepage": "https://github.com/mustafa/clipmer",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --linux AppImage deb rpm snap"
  },
  "dependencies": {
    "electron-store": "8.2.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.clipmer.app",
    "productName": "Clipmer",
    "linux": {
      "target": ["AppImage", "deb", "rpm", "snap"],
      "icon": "assets/icons/",
      "category": "Utility"
    },
    "deb": {
      "depends": ["at-spi2-core"],
      "afterInstall": "build/postinst.sh"
    },
    "rpm": {
      "depends": ["at-spi2-core"],
      "afterInstall": "build/postinst.sh"
    },
    "snap": {
      "summary": "Clipboard history manager for Linux",
      "confinement": "strict",
      "grade": "stable",
      "base": "core22",
      "compression": "lzo",
      "plugs": [
        "home",
        "desktop",
        "desktop-legacy",
        "wayland",
        "x11",
        "unity7",
        "gsettings",
        "process-control",
        "browser-support",
        "opengl"
      ],
      "stagePackages": [
        "default",
        "libsecret-1-0"
      ]
    }
  }
}
