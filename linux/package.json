{
  "name": "clipmer",
  "version": "3.0.1",
  "description": "Clipboard history manager for Linux",
  "author": {
    "name": "Mustafa",
    "email": "mustafa@clipmer.local"
  },
  "homepage": "https://github.com/mustafa/clipmer",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --linux AppImage deb rpm"
  },
  "dependencies": {
    "electron-store": "8.2.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.clipmer.app",
    "productName": "Clipmer",
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "assets/icons/",
      "category": "Utility"
    },
    "deb": {
      "depends": ["at-spi2-core"],
      "afterInstall": "build/postinst.sh"
    },
    "rpm": {
      "depends": ["at-spi2-core"],
      "afterInstall": "build/postinst.sh"
    }
  }
}
